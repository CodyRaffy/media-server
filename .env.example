# ==============================================================================
# Media Server Configuration
# ==============================================================================
# Copy this file to .env and update the values for your setup:
#   cp .env.example .env
# ==============================================================================

# Your timezone (find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/New_York

# Path where the NAS music share is mounted on the Pi
MUSIC_PATH=/mnt/music

# rclone remote name (as configured during rclone config)
RCLONE_REMOTE=dropbox

# Path to your music folder inside Dropbox (e.g., /Music, /Media/CDs, etc.)
DROPBOX_MUSIC_PATH=/Music

# How often to sync from Dropbox (in seconds)
# 21600 = 6 hours | 43200 = 12 hours | 86400 = 24 hours
SYNC_INTERVAL=21600

# NAS connection details (used by mount script)
NAS_IP=192.168.1.100
NAS_SHARE=Music
NAS_USERNAME=your_nas_username
NAS_PASSWORD=your_nas_password
